generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Task {
  id        Int      @id @default(autoincrement())
  title     String
  city      String
  address   String
  budget    Int
  deadline  DateTime
  notes     String
  status    String   @default("OPEN")
  report    String?
  rating    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScoutProfile {
  id        Int      @id @default(autoincrement())
  name      String
  city      String
  bio       String?
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
